@startuml

!$stylePath = "https://raw.githubusercontent.com/olek3/plantuml-includes/refs/heads/main/iuml"
!include $stylePath/reading.iuml


title Hot Butter Cuttlefish by Ashok Ferrey

mainframe characters

!$page = 21
!$pages = 260
!$progress =$page*1000/$pages
!$progress = $progress / 10 + "." + %mod( $progress , 10)
!$chapter = 3

legend: p $page/$pages $progress% (Chapter $chapter/27)

:Malik: as I <<narrator>> $male_protagonist

:Arthur Reginald de Fonseca: as Arthur $male

I <-- Arthur : client

:Fiona: <<mentioned>> $female

Fiona  --> I $ex wife

:Chanchalla:

Arthur <-- Chanchalla : ballet student

:Kamala: $female

Arthur --> Kamala : employer

:Fritzi: <<pet>> $male

Fritzi --> I : dog 

:Achi: $female 

Kamala <-- Achi: grandmother


@enduml